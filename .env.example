# Simulations-Modus (kein echter Router / Nintendo nötig)
USE_MOCK_ADAPTERS=true

# Router-/Konsolen-Zugangsdaten (Fritz!Box, MikroTik, Nintendo)
# werden pro Gerät in der Admin-Geräteverwaltung (UI) konfiguriert.

# Admin PIN (Klartext) - Standard ist 1234, einfach ändern
ADMIN_PIN=1234

# Security
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-chars
