{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Backend + Frontend",
      "configurations": ["Backend (ASP.NET)", "Frontend (vite)"],
      "stopAll": true
    }
  ],
  "configurations": [
    {
      "name": "Backend (ASP.NET)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/backend-dotnet/MuenzboxApi/MuenzboxApi.csproj",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DATABASE_PATH": "${workspaceFolder}/data/muenzbox.db",
        // Set to a valid libpython path on your dev machine, e.g.:
        //   macOS (homebrew):  /opt/homebrew/opt/python@3.12/Frameworks/Python.framework/Versions/3.12/lib/libpython3.12.dylib
        //   Linux:             /usr/lib/x86_64-linux-gnu/libpython3.12.so.1.0
        //   Windows:           C:\Python312\python312.dll
        "PYTHONNET_PYDLL": "",
        "USE_MOCK_ADAPTERS": "true"
      },
      "logging": {
        "moduleLoad": false
      }
    },
    {
      "name": "Frontend (vite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal"
    }
  ]
}
